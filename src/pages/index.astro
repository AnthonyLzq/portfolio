---
import Layout from '../layouts/Layout.astro'
import Main from '../components/Main.astro'
import { SITE } from '../site'
---

<Layout title={SITE.title} type='profile'>
  <Main />
</Layout>

<style>
  main {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-height: calc(100vh - 66px);
  }
</style>
