---
import ProjectItem, {
  type Props as ProjectItemProps
} from '../components/ProjectItem.astro'
import Layout from '../layouts/Layout.astro'
import acecomLogo from '../static/images/acecom-logo.svg'
import uniLogo from '../static/images/uni-logo-transparente-granate.png'
import { tech } from '../utils'

const projects: ProjectItemProps[] = [
  {
    title: 'Simba.js',
    description: 'TypeScript framework for backend development.',
    role: 'Creator / maintainer',
    status: 'Open source',
    highlights: [
      'Framework and CLI for starting TypeScript APIs faster.',
      'Supports REST, GraphQL, Express, Fastify and Prisma workflows.'
    ],
    image:
      'https://raw.githubusercontent.com/AnthonyLzq/Simba.js/v7.2.1/static/simba.png',
    url: 'https://github.com/AnthonyLzq/simba.js',
    links: [
      {
        href: 'https://github.com/AnthonyLzq/simba.js',
        label: 'View source',
        variant: 'primary'
      }
    ],
    tech: [
      tech.typescript,
      tech.javascript,
      tech.node,
      tech.express,
      tech.fastify,
      tech.graphql,
      tech.mongo,
      tech.postgres
    ],
    paddingTop: '1.25rem'
  },
  {
    title: 'TypeScript Project Generator',
    description: 'Minimalist TypeScript project generator for Node.js.',
    role: 'Creator / maintainer',
    status: 'Open source',
    highlights: [
      'CLI for bootstrapping TypeScript projects with less repetitive setup.',
      'Focused on Node.js tooling and project conventions.'
    ],
    image:
      'https://raw.githubusercontent.com/AnthonyLzq/typescript-project-generator/master/static/TypeScript-Project-Generator.png',
    url: 'https://github.com/AnthonyLzq/typescript-project-generator',
    links: [
      {
        href: 'https://github.com/AnthonyLzq/typescript-project-generator',
        label: 'View source',
        variant: 'primary'
      }
    ],
    tech: [tech.typescript, tech.javascript, tech.node],
    paddingTop: '1.25rem'
  },
  {
    title: 'ACECOM',
    description: "ACECOM's web page.",
    role: 'Web project',
    status: 'Live site',
    highlights: [
      'Public website built with a modern Remix and React stack.',
      'Integrated with Supabase, Prisma and Material UI.'
    ],
    image: acecomLogo.src,
    url: 'https://www.acecom.dev',
    links: [
      {
        href: 'https://www.acecom.dev',
        label: 'Open site',
        variant: 'primary'
      }
    ],
    tech: [
      tech.typescript,
      tech.remix,
      tech.react,
      tech.material,
      tech.supabase,
      tech.prisma
    ],
    objectFit: 'contain',
    boxSizing: 'border-box',
    paddingTop: '1.25rem'
  },
  {
    title: 'Thesis Project II',
    description:
      'Real Time Face Recognition and Communication using IoT protocols',
    role: 'Thesis project',
    status: 'Live demo',
    highlights: [
      'Face recognition and real-time communication using IoT protocols.',
      'Combines web dashboards, MQTT, TensorFlow and Raspberry Pi devices.'
    ],
    image: uniLogo.src,
    url: 'https://thesis2.anthonylzq.dev',
    links: [
      {
        href: 'https://thesis2.anthonylzq.dev',
        label: 'Open demo',
        variant: 'primary'
      }
    ],
    tech: [
      tech.typescript,
      tech.node,
      tech.remix,
      tech.react,
      tech.material,
      tech['chart.js'],
      tech['mqtt.js'],
      tech.tensorflow,
      tech.raspberry
    ],
    objectFit: 'contain',
    boxSizing: 'border-box',
    paddingTop: '8px'
  },
  {
    title: 'node-webcam',
    description: 'Node.js Cross-platform webcam module.',
    role: 'Open source maintainer',
    status: 'Node package',
    highlights: [
      'Cross-platform webcam integration for Node.js projects.',
      'Useful for automation, image capture and hardware-adjacent workflows.'
    ],
    image:
      'https://raw.githubusercontent.com/AnthonyLzq/node-webcam/master/static/node-webcam.png',
    url: 'https://github.com/AnthonyLzq/node-webcam',
    links: [
      {
        href: 'https://github.com/AnthonyLzq/node-webcam',
        label: 'View source',
        variant: 'primary'
      }
    ],
    tech: [tech.typescript, tech.javascript, tech.node],
    paddingTop: '1.25rem'
  },
  {
    title: 'Sum Time',
    description: 'Sum time in hours, minutes and seconds.',
    role: 'Utility app',
    status: 'Certificate renewal pending',
    highlights: [
      'Small utility for adding durations in hours, minutes and seconds.',
      'Built as a lightweight Astro and React application.'
    ],
    links: [
      {
        label: 'Demo pending certificate'
      }
    ],
    tech: [tech.astro, tech.typescript, tech.react]
  },
  {
    title: 'Color Generator',
    description: 'Get shades of CSS color.',
    role: 'Utility app',
    status: 'Live demo',
    highlights: [
      'Generates CSS color shades for interface work.',
      'Built as a lightweight Astro and React application.'
    ],
    url: 'https://cg.anthonylzq.dev',
    links: [
      {
        href: 'https://cg.anthonylzq.dev',
        label: 'Open demo',
        variant: 'primary'
      }
    ],
    tech: [tech.astro, tech.typescript, tech.react]
  }
]
---

<Layout
  title='Projects | AnthonyLzq'
  description='A selection of projects by Anthony Luzquiños, including TypeScript APIs, developer tooling, web applications and IoT experiments.'
>
  <div class='projects-page'>
    <h1>Projects</h1>
    <p class='projects-intro'>
      Selected work across backend frameworks, developer tooling, web products,
      utilities and IoT experiments.
    </p>
    <section class='projects-grid'>
      {projects.map(project => <ProjectItem {...project} />)}
    </section>
  </div>
</Layout>

<style>
  .projects-page {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .projects-intro {
    color: #333;
    font-size: 1.2rem;
    margin-bottom: 2rem;
    max-width: 760px;
    text-wrap: balance;
  }

  .projects-grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 420px), 1fr));
  }
</style>
