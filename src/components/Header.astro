---
import logo from '../static/images/logo.svg'
---

<header>
  <img src={logo.src} alt='AnthonyLzq logo' />
  <nav aria-label='Main navigation'>
    <button
      class='menu-toggle'
      type='button'
      aria-expanded='false'
      aria-controls='main-navigation'
    >
      <span class='sr-only'>Toggle navigation menu</span>
      <span aria-hidden='true'>☰</span>
    </button>
    <ul id='main-navigation' class='nav-list' data-open='false'>
      <li><a href='/'>About me</a></li>
      <li><a href='/experience'>Experience</a></li>
      <li><a href='/projects'>Projects</a></li>
      <li><a href='/blog'>Blog</a></li>
      <li><a href='/contact'>Contact</a></li>
    </ul>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2rem;
    background-color: #fff;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    height: 66px;
  }

  nav {
    display: flex;
    align-items: center;
  }

  header img {
    width: 2.5rem;
    height: 2.5rem;
  }

  .menu-toggle {
    display: none;
  }

  .sr-only {
    width: 1px;
    height: 1px;
    position: absolute;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .nav-list {
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1rem;
    z-index: 2;
  }

  .nav-list li {
    font-size: 1.2rem;
    font-weight: 500;
    color: #000;
    cursor: pointer;
  }

  .nav-list li:hover {
    color: #666;
  }

  .nav-list li a {
    text-decoration: none;
    color: #000;
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 44px;
      min-height: 44px;
      padding: 0;
      border: 0;
      background-color: transparent;
      font-size: 2rem;
      cursor: pointer;
    }

    .nav-list {
      position: fixed;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      right: 36px;
      top: 52px;
      align-items: flex-end;
      background-color: #fff;
      padding: 0.5rem 0.5rem 0.75rem;
      border-radius: 4px;
      text-align: end;
      min-width: 86px;
    }

    .nav-list[data-open='false'] {
      display: none;
    }

    .nav-list li {
      width: 100%;
    }

    .nav-list li::after {
      content: ' ';
      display: block;
      width: 10%;
      height: 1px;
      background-color: #000;
      transition: width 0.3s;
      position: absolute;
      right: 10px;
      margin-top: 2px;
    }

    .nav-list li:hover::after {
      animation: bigger 0.2s linear forwards;
    }

    @keyframes bigger {
      0% {
        height: 1px;
      }
      100% {
        height: 4px;
      }
    }
  }
</style>

<script>
  const menuToggle = document.querySelector<HTMLButtonElement>('.menu-toggle')
  const menu = document.querySelector<HTMLUListElement>('#main-navigation')

  const setMenuOpen = (open: boolean) => {
    menuToggle?.setAttribute('aria-expanded', String(open))
    menu?.setAttribute('data-open', String(open))
  }

  menuToggle?.addEventListener('click', () => {
    const isOpen = menuToggle.getAttribute('aria-expanded') === 'true'

    setMenuOpen(!isOpen)
  })

  menu?.addEventListener('click', event => {
    if (event.target instanceof HTMLAnchorElement) {
      setMenuOpen(false)
    }
  })

  document.addEventListener('keydown', event => {
    if (event.key === 'Escape') {
      setMenuOpen(false)
    }
  })
</script>
