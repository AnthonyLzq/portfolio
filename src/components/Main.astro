---
import Social from './Social'
import profilePhoto from '../static/images/profile.png'
import logoAndName from '../static/images/logo-and-name.svg'
---

<article class='profile'>
  <div class='profile__container'>
    <section class='profile__description'>
      <div class='profile__logo-container'>
        <img
          class='profile__logo'
          src={logoAndName.src}
          alt='AnthonyLzq svg logo'
        />
      </div>

      <div class='profile__photo-container'>
        <img
          class='profile__photo'
          src={profilePhoto.src}
          alt='AnthonyLzq profile photo'
        />
      </div>
      <p class='profile__eyebrow'>Full Stack Developer</p>
      <h1 class='profile__title'>
        I build TypeScript products, APIs and developer tools.
      </h1>
      <p class='profile__description-text'>
        I work across React frontends, Node.js APIs and automation, with a focus
        on clear architecture and practical products that are easy to evolve.
      </p>
      <div class='profile__highlights' aria-label='Main skills'>
        <span>TypeScript-first</span>
        <span>React + Node.js</span>
        <span>APIs and automation</span>
      </div>
      <Social />
    </section>

    <section class='profile__photo-container-2'>
      <img
        class='profile__photo'
        src={profilePhoto.src}
        alt='AnthonyLzq profile photo'
      />
    </section>
  </div>
</article>

<style>
  .profile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: calc(100vh - 66px - 2rem);
  }

  .profile__container {
    display: flex;
    flex-direction: row;
    align-items: center;
    column-gap: 2rem;
    width: 64%;
  }

  section {
    display: flex;
    flex-direction: column;
  }

  .profile__description {
    row-gap: 1rem;
  }

  .profile__photo-container {
    display: none;
  }

  .profile__logo-container {
    width: 100%;
    height: 200px;
  }

  .profile__logo {
    height: 200px;
  }

  .profile__eyebrow {
    color: #2563eb;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    margin: 0;
    text-transform: uppercase;
  }

  .profile__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    margin: 0;
    text-wrap: balance;
  }

  .profile__description-text {
    text-wrap: balance;
    color: #333;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }

  .profile__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .profile__highlights span {
    background-color: #fff;
    border: 1px solid lightblue;
    border-radius: 999px;
    color: #1f2937;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.5rem 0.85rem;
  }

  .profile__photo {
    width: 300px;
    height: 300px;
    border-radius: 50%;
  }

  @media screen and (width <= 1720px) {
    .profile__container {
      width: 70%;
    }
  }

  @media screen and (width <= 1600px) {
    .profile__container {
      width: 75%;
    }
  }

  @media screen and (width <= 1520px) {
    .profile__container {
      width: 80%;
    }
  }

  @media screen and (width <= 1380px) {
    .profile__container {
      width: 85%;
    }
  }

  @media screen and (width <= 1280px) {
    .profile__container {
      width: 90%;
    }
  }

  @media screen and (width <= 1214px) {
    .profile__container {
      width: 95%;
    }
  }

  @media screen and (width <= 1124px) {
    .profile {
      flex-direction: column;
      text-align: center;
    }

    section {
      align-items: center;
    }

    .profile__title {
      font-size: 2rem;
    }

    .profile__description-text {
      font-size: 1.2rem;
      width: 80%;
    }

    .profile__highlights {
      justify-content: center;
    }

    .profile__photo-container {
      display: block;
    }

    .profile__photo-container-2 {
      display: none;
    }
  }

  @media screen and (width <= 844px) {
    .profile__description-text {
      width: 90%;
    }
  }

  @media screen and (width <= 768px) {
    .profile__logo-container {
      height: auto;
    }

    .profile__logo {
      height: auto;
      width: 100%;
    }

    .profile__description-text {
      width: 100%;
    }
  }

  @media screen and (width <= 540px) {
    .profile__photo {
      width: 240px;
      height: auto;
    }
  }

  @media screen and (width <= 400px) {
    .profile__photo {
      width: 200px;
      height: auto;
    }

    .profile__description-text {
      font-size: 1rem;
    }
  }
</style>
